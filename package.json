{
  "name": "flashcard-app",
  "version": "1.0.0",
  "type": "module",
  "description": "Flashcard CRUD app with Express + Tailwind CSS",
  "main": "server.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/styles.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"node server.js\"",
    "start": "npm run build:css && node server.js",
    "db:init": "node db/init-db.js",
    "db:test": "node db/test-db.js",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "seed": "node db/seed.js",
    "purge": "node db/purge.js",
    "export": "node db/export.js",
    "restore": "node db/restore.js"

  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^9.0.0",
    "dompurify": "^3.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "isomorphic-dompurify": "^3.12.0",
    "pg": "^8.20.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.0"
  }
}
