# Database connection
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/flashcards_db

# Session secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-random-hex-string

